# Copy this file to .env and fill in real values. Never commit the actual .env file.

PORT=5050

# Local MongoDB by default. Switch to an Atlas connection string later if/when hosting.
MONGO_URI=mongodb://127.0.0.1:27017/sheryatri

# Use a long random string in real use. This is just a placeholder.
JWT_SECRET=change_this_to_a_long_random_string

# Allowed origin for the admin panel / public site during local dev
CLIENT_URL=http://localhost:5173
